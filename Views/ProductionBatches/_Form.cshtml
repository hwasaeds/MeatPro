@model MeatPro.ViewModels.ProductionBatchFormViewModel

<div class="page-card p-4 p-lg-5">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-lg-6">
                <label asp-for="BatchNumber" class="form-label"></label>
                <input asp-for="BatchNumber" class="form-control" placeholder="BATCH-2026-0001" />
                <span asp-validation-for="BatchNumber" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="WorkOrderId" class="form-label"></label>
                <select asp-for="WorkOrderId" asp-items="@(new SelectList(Model.WorkOrders, "Id", "WorkOrderNumber"))" class="form-select">
                    <option value="">-- Select work order --</option>
                </select>
                <span asp-validation-for="WorkOrderId" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="ProductId" class="form-label"></label>
                <select asp-for="ProductId" asp-items="@(new SelectList(Model.Products, "Id", "Name"))" class="form-select">
                    <option value="">-- Select product --</option>
                </select>
                <span asp-validation-for="ProductId" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="TraceabilityCode" class="form-label"></label>
                <input asp-for="TraceabilityCode" class="form-control" placeholder="TRACE-2026-0001" />
                <span asp-validation-for="TraceabilityCode" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="RawMaterialConsumed" class="form-label"></label>
                <input asp-for="RawMaterialConsumed" type="number" step="0.01" class="form-control" placeholder="220" />
                <span asp-validation-for="RawMaterialConsumed" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="ProducedQuantity" class="form-label"></label>
                <input asp-for="ProducedQuantity" type="number" step="0.01" class="form-control" placeholder="180" />
                <span asp-validation-for="ProducedQuantity" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="ProducedAt" class="form-label"></label>
                <input asp-for="ProducedAt" type="datetime-local" class="form-control" />
                <span asp-validation-for="ProducedAt" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="ExpirationDate" class="form-label"></label>
                <input asp-for="ExpirationDate" type="date" class="form-control" />
                <span asp-validation-for="ExpirationDate" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Traceable output batch"></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>
        </div>
</div>
