@model MeatPro.ViewModels.RoleIndexViewModel
@{
    ViewData["Title"] = "Roles & Permissions";
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Administration</div>
            <h1 class="h3 mb-1">Roles & Permissions</h1>
            <p class="text-secondary mb-0">Configure RBAC for ERP operations.</p>
        </div>
        <a asp-action="RoleCreate" class="btn btn-meatpro"><i class="bi bi-plus-lg me-2"></i>New Role</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <form method="get" class="module-toolbar mb-4">
        <div class="toolbar-group flex-grow-1">
            <div class="search-shell flex-grow-1" style="max-width: 420px;">
                <i class="bi bi-search"></i>
                <input asp-for="Search" type="search" class="form-control" placeholder="Search roles" />
            </div>
            <button type="submit" class="btn btn-outline-meatpro">Apply</button>
            <a asp-action="RoleIndex" class="btn btn-link text-decoration-none">Reset</a>
        </div>
    </form>

    <div class="table-wrap">
        <table class="table erp-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Role</th>
                    <th>Users</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="3" class="text-center text-secondary py-5">No roles found.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.UserCount</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Role actions">
                                    <a asp-action="RoleDetails" asp-route-id="@item.Id" class="btn btn-outline-meatpro"><i class="bi bi-eye me-1"></i>View</a>
                                    <a asp-action="RoleEdit" asp-route-id="@item.Id" class="btn btn-outline-meatpro"><i class="bi bi-pencil me-1"></i>Edit</a>
                                    <a asp-action="RoleDelete" asp-route-id="@item.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-secondary small">Showing @Model.Items.Count of @Model.TotalItems records</div>
    </div>
</div>
