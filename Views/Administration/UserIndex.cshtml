@model MeatPro.ViewModels.UserIndexViewModel
@{
    ViewData["Title"] = "User Management";
    var startPage = Math.Max(1, Model.PageNumber - 2);
    var endPage = Math.Min(Model.TotalPages, startPage + 4);
    if (endPage - startPage < 4)
    {
        startPage = Math.Max(1, endPage - 4);
    }
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Administration</div>
            <h1 class="h3 mb-1">User Management</h1>
            <p class="text-secondary mb-0">Manage operators, roles, and access control.</p>
        </div>
        <a asp-action="UserCreate" class="btn btn-meatpro"><i class="bi bi-plus-lg me-2"></i>New User</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <div class="dashboard-grid mb-4">
        <div class="span-4 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Total Users</div>
                <strong class="metric-value">@Model.TotalItems</strong>
            </div>
            <div class="metric-caption mt-1">System accounts</div>
        </div>
        <div class="span-4 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Active</div>
                <strong class="metric-value">@Model.ActiveCount</strong>
            </div>
            <div class="metric-caption mt-1">Currently unlocked</div>
        </div>
        <div class="span-4 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Locked</div>
                <strong class="metric-value">@Model.LockedCount</strong>
            </div>
            <div class="metric-caption mt-1">Access disabled</div>
        </div>
    </div>

    <form method="get" class="module-toolbar mb-4">
        <div class="toolbar-group flex-grow-1">
            <div class="search-shell flex-grow-1" style="max-width: 420px;">
                <i class="bi bi-search"></i>
                <input asp-for="Search" type="search" class="form-control" placeholder="Search users" />
            </div>
            <select asp-for="Sort" class="form-select">
                <option value="username">Username A-Z</option>
                <option value="username_desc">Username Z-A</option>
                <option value="email">Email A-Z</option>
                <option value="email_desc">Email Z-A</option>
                <option value="name">Full Name A-Z</option>
                <option value="name_desc">Full Name Z-A</option>
            </select>
            <button type="submit" class="btn btn-outline-meatpro">Apply</button>
            <a asp-action="UserIndex" class="btn btn-link text-decoration-none">Reset</a>
        </div>
    </form>

    <div class="table-wrap">
        <table class="table erp-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Full Name</th>
                    <th>Department</th>
                    <th>Roles</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-secondary py-5">No users found.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.UserName</td>
                            <td>@item.Email</td>
                            <td>@item.FullName</td>
                            <td>@item.Department</td>
                            <td>@item.Roles</td>
                            <td><span class="fw-semibold text-@item.StatusTone">@item.Status</span></td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group" aria-label="User actions">
                                    <a asp-action="UserDetails" asp-route-id="@item.Id" class="btn btn-outline-meatpro"><i class="bi bi-eye me-1"></i>View</a>
                                    <a asp-action="UserEdit" asp-route-id="@item.Id" class="btn btn-outline-meatpro"><i class="bi bi-pencil me-1"></i>Edit</a>
                                    <a asp-action="UserDelete" asp-route-id="@item.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-3">
        <div class="text-secondary small">Showing @Model.Items.Count of @Model.TotalItems records</div>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="text-secondary small">Page @Model.PageNumber of @Model.TotalPages</div>
            <nav aria-label="Users pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="UserIndex" asp-route-search="@Model.Search" asp-route-sort="@Model.Sort" asp-route-page="@(Model.PageNumber - 1)"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                    {
                        <li class="page-item @(pageNumber == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-action="UserIndex" asp-route-search="@Model.Search" asp-route-sort="@Model.Sort" asp-route-page="@(pageNumber)">@pageNumber</a>
                        </li>
                    }
                    <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="UserIndex" asp-route-search="@Model.Search" asp-route-sort="@Model.Sort" asp-route-page="@(Model.PageNumber + 1)"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
