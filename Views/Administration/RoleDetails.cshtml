@model MeatPro.ViewModels.RoleDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Administration</div>
            <h1 class="h3 mb-1">@Model.Name</h1>
            <p class="text-secondary mb-0">@Model.UserCount user(s) assigned</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="RoleEdit" asp-route-id="@Model.Id" class="btn btn-meatpro"><i class="bi bi-pencil me-1"></i>Edit</a>
            <a asp-action="RoleDelete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</a>
            <a asp-action="RoleIndex" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to list</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
    }

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="page-card p-4 h-100">
                <h2 class="h6 text-uppercase text-secondary mb-3">Role details</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-secondary">Role Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4 text-secondary">Users</dt>
                    <dd class="col-sm-8">@Model.UserCount</dd>
                </dl>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="page-card p-4 h-100">
                <h2 class="h6 text-uppercase text-secondary mb-3">Assigned Users</h2>
                @if (Model.Users.Count == 0)
                {
                    <p class="text-secondary mb-0">No users assigned to this role.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var user in Model.Users)
                        {
                            <li class="py-1 border-bottom border-light">@user</li>
                        }
                    </ul>
                }
                <a asp-action="RoleEdit" asp-route-id="@Model.Id" class="btn btn-meatpro w-100 mt-3"><i class="bi bi-person-plus me-1"></i>Manage Assignments</a>
            </div>
        </div>
    </div>
</div>
