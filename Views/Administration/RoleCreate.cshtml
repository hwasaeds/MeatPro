@model MeatPro.ViewModels.RoleFormViewModel
@{
    ViewData["Title"] = "New Role";
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Administration</div>
            <h1 class="h3 mb-1">Create Role</h1>
            <p class="text-secondary mb-0">Add a new permission set to the system.</p>
        </div>
        <a asp-action="RoleIndex" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to list</a>
    </div>

    <form asp-action="RoleCreate" method="post" class="vstack gap-4">
        <partial name="RoleForm" model="Model" />
        <div class="d-flex justify-content-end gap-2">
            <a asp-action="RoleIndex" class="btn btn-outline-meatpro"><i class="bi bi-x-lg me-1"></i>Cancel</a>
            <button type="submit" class="btn btn-meatpro"><i class="bi bi-check-lg me-1"></i>Save Role</button>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
