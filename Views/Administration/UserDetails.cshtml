@model MeatPro.ViewModels.UserDetailsViewModel
@{
    ViewData["Title"] = Model.FullName;
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Administration</div>
            <h1 class="h3 mb-1">@Model.FullName</h1>
            <p class="text-secondary mb-0">@@@Model.UserName | @Model.Email</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="UserEdit" asp-route-id="@Model.Id" class="btn btn-meatpro"><i class="bi bi-pencil me-1"></i>Edit</a>
            <a asp-action="UserDelete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</a>
            <a asp-action="UserIndex" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to list</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
    }

    <div class="dashboard-grid mb-4">
        <div class="span-4 metric-card">
            <div class="metric-caption">Status</div>
            <strong class="metric-value">@Model.Status</strong>
            <div class="metric-caption mt-1">Account state</div>
        </div>
        <div class="span-4 metric-card">
            <div class="metric-caption">Department</div>
            <strong class="metric-value">@Model.Department</strong>
            <div class="metric-caption mt-1">Assigned unit</div>
        </div>
        <div class="span-4 metric-card">
            <div class="metric-caption">Roles</div>
            <strong class="metric-value">@Model.Roles.Count</strong>
            <div class="metric-caption mt-1">Assigned roles</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="page-card p-4 h-100">
                <h2 class="h6 text-uppercase text-secondary mb-3">User details</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-secondary">Username</dt>
                    <dd class="col-sm-8">@Model.UserName</dd>

                    <dt class="col-sm-4 text-secondary">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4 text-secondary">Full Name</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>

                    <dt class="col-sm-4 text-secondary">Department</dt>
                    <dd class="col-sm-8">@Model.Department</dd>

                    <dt class="col-sm-4 text-secondary">Phone</dt>
                    <dd class="col-sm-8">@(Model.PhoneNumber ?? "-")</dd>

                    <dt class="col-sm-4 text-secondary">Roles</dt>
                    <dd class="col-sm-8">
                        @if (Model.Roles.Count == 0)
                        {
                            <span class="text-secondary">None</span>
                        }
                        else
                        {
                            @string.Join(", ", Model.Roles)
                        }
                    </dd>

                    <dt class="col-sm-4 text-secondary">Locked Out</dt>
                    <dd class="col-sm-8">@(Model.IsLockedOut ? "Yes" : "No")</dd>
                </dl>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-card p-4 h-100">
                <h2 class="h6 text-uppercase text-secondary mb-3">Status</h2>
                <span class="badge text-bg-@Model.StatusTone mb-3">@Model.Status</span>
                <p class="text-secondary mb-3">This account is currently @(Model.IsLockedOut ? "locked and cannot sign in." : "active with full access.")</p>
                <a asp-action="UserEdit" asp-route-id="@Model.Id" class="btn btn-meatpro w-100 mb-2"><i class="bi bi-pencil me-1"></i>Edit User</a>
                <a asp-action="UserDelete" asp-route-id="@Model.Id" class="btn btn-outline-danger w-100"><i class="bi bi-trash me-1"></i>Delete User</a>
            </div>
        </div>
    </div>
</div>
