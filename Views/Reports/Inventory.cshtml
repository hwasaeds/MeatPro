@model MeatPro.ViewModels.InventoryReportViewModel
@{
    ViewData["Title"] = "Inventory Report";
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Reports</div>
            <h1 class="h3 mb-1">Inventory Report</h1>
            <p class="text-secondary mb-0">Stock levels, values, and reorder analysis across raw materials and finished goods</p>
        </div>
        <a asp-action="ExportInventoryCsv" asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo" asp-route-statusFilter="@Model.StatusFilter" class="btn btn-meatpro"><i class="bi bi-download me-1"></i>Export CSV</a>
    </div>

    <form method="get" class="module-toolbar mb-4">
        <div class="toolbar-group flex-grow-1 gap-2">
            <div>
                <label class="form-label small text-secondary mb-1">From</label>
                <input type="date" name="dateFrom" class="form-control" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label class="form-label small text-secondary mb-1">To</label>
                <input type="date" name="dateTo" class="form-control" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label class="form-label small text-secondary mb-1">Status</label>
                <select name="statusFilter" class="form-select">
                    <option value="">All</option>
                    <option value="Healthy" selected="@(Model.StatusFilter == "Healthy")">Healthy</option>
                    <option value="Low stock" selected="@(Model.StatusFilter == "Low stock")">Low Stock</option>
                    <option value="Expiring" selected="@(Model.StatusFilter == "Expiring")">Expiring</option>
                </select>
            </div>
            <div class="d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-meatpro">Apply</button>
                <a asp-action="Inventory" class="btn btn-link text-decoration-none">Reset</a>
            </div>
        </div>
    </form>

    <div class="dashboard-grid mb-4">
        <div class="span-3 metric-card">
            <div class="metric-caption">Total Items</div>
            <strong class="metric-value">@Model.TotalMaterials</strong>
            <div class="metric-caption mt-1">Raw materials + finished goods</div>
        </div>
        <div class="span-3 metric-card">
            <div class="metric-caption">Total Stock Value</div>
            <strong class="metric-value">@Model.TotalStockValue.ToString("C")</strong>
            <div class="metric-caption mt-1">Estimated inventory value</div>
        </div>
        <div class="span-3 metric-card">
            <div class="metric-caption">Low Stock</div>
            <strong class="metric-value">@Model.LowStockCount</strong>
            <div class="metric-caption mt-1">Below reorder level</div>
        </div>
        <div class="span-3 metric-card">
            <div class="metric-caption">Expiring</div>
            <strong class="metric-value">@Model.ExpiringCount</strong>
            <div class="metric-caption mt-1">Within 14 days</div>
        </div>
    </div>

    <div class="table-wrap">
        <table class="table erp-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Name</th>
                    <th>SKU</th>
                    <th class="text-end">Stock</th>
                    <th class="text-end">Reorder</th>
                    <th class="text-end">Unit Value</th>
                    <th class="text-end">Total Value</th>
                    <th>Location</th>
                    <th>Expires</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="10" class="text-center text-secondary py-5">No inventory items found.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><span class="badge text-bg-@(item.Type == "Raw Material" ? "primary" : "success")">@item.Type</span></td>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.SKU</td>
                            <td class="text-end">@item.CurrentStock.ToString("N0")</td>
                            <td class="text-end">@item.ReorderLevel.ToString("N0")</td>
                            <td class="text-end">@item.UnitValue.ToString("C")</td>
                            <td class="text-end">@item.TotalValue.ToString("C")</td>
                            <td>@item.StorageLocation</td>
                            <td>@(item.ExpirationDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>
                                <span class="badge text-bg-@(item.Status == "Healthy" ? "success" : item.Status == "Low stock" ? "warning" : "danger")">@item.Status</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-secondary small">Showing @Model.Items.Count records</div>
        <a asp-action="ExportInventoryCsv" asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo" asp-route-statusFilter="@Model.StatusFilter" class="btn btn-outline-meatpro btn-sm"><i class="bi bi-download me-1"></i>Export CSV</a>
    </div>
</div>
