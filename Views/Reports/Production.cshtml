@model MeatPro.ViewModels.ProductionReportViewModel
@{
    ViewData["Title"] = "Production Report";
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Reports</div>
            <h1 class="h3 mb-1">Production Report</h1>
            <p class="text-secondary mb-0">Output trends, yield efficiency, and batch analysis across work orders</p>
        </div>
        <a asp-action="ExportProductionCsv" asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo" asp-route-statusFilter="@Model.StatusFilter" class="btn btn-meatpro"><i class="bi bi-download me-1"></i>Export CSV</a>
    </div>

    <form method="get" class="module-toolbar mb-4">
        <div class="toolbar-group flex-grow-1 gap-2">
            <div>
                <label class="form-label small text-secondary mb-1">From</label>
                <input type="date" name="dateFrom" class="form-control" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label class="form-label small text-secondary mb-1">To</label>
                <input type="date" name="dateTo" class="form-control" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label class="form-label small text-secondary mb-1">Status</label>
                <select name="statusFilter" class="form-select">
                    <option value="">All</option>
                    <option value="Good" selected="@(Model.StatusFilter == "Good")">Good</option>
                    <option value="Expiring" selected="@(Model.StatusFilter == "Expiring")">Expiring</option>
                </select>
            </div>
            <div class="d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-meatpro">Apply</button>
                <a asp-action="Production" class="btn btn-link text-decoration-none">Reset</a>
            </div>
        </div>
    </form>

    <div class="dashboard-grid mb-4">
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Total Work Orders</div>
                <strong class="metric-value">@Model.TotalWorkOrders</strong>
            </div>
            <div class="metric-caption mt-1">All time</div>
        </div>
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Completed</div>
                <strong class="metric-value">@Model.CompletedOrders</strong>
            </div>
            <div class="metric-caption mt-1">Fully finished</div>
        </div>
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Total Produced</div>
                <strong class="metric-value">@Model.TotalProduced.ToString("N0")</strong>
            </div>
            <div class="metric-caption mt-1">Units output</div>
        </div>
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Raw Material Consumed</div>
                <strong class="metric-value">@Model.TotalConsumed.ToString("N0")</strong>
            </div>
            <div class="metric-caption mt-1">Total used</div>
        </div>
    </div>

    <div class="table-wrap">
        <table class="table erp-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Batch #</th>
                    <th>Product</th>
                    <th>Work Order</th>
                    <th>Plan Code</th>
                    <th class="text-end">Produced</th>
                    <th class="text-end">Consumed</th>
                    <th class="text-end">Yield %</th>
                    <th>Produced At</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="9" class="text-center text-secondary py-5">No production batches found.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.BatchNumber</td>
                            <td>@item.ProductName</td>
                            <td>@item.WorkOrderNumber</td>
                            <td>@item.PlanCode</td>
                            <td class="text-end">@item.ProducedQuantity.ToString("N0")</td>
                            <td class="text-end">@item.RawMaterialConsumed.ToString("N0")</td>
                            <td class="text-end">
                                <span class="fw-semibold text-@(item.Yield >= 90 ? "success" : item.Yield >= 75 ? "warning" : "danger")">@item.Yield%</span>
                            </td>
                            <td>@item.ProducedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="fw-semibold text-@(item.Status == "Good" ? "success" : "warning")">@item.Status</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-secondary small">Showing @Model.Items.Count records</div>
        <a asp-action="ExportProductionCsv" asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo" asp-route-statusFilter="@Model.StatusFilter" class="btn btn-outline-meatpro btn-sm"><i class="bi bi-download me-1"></i>Export CSV</a>
    </div>
</div>
