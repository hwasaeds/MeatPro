@model MeatPro.ViewModels.SalesReportViewModel
@{
    ViewData["Title"] = "Sales Report";
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Reports</div>
            <h1 class="h3 mb-1">Sales Report</h1>
            <p class="text-secondary mb-0">Finished goods available for sale, revenue potential, and stock status</p>
        </div>
        <a asp-action="ExportSalesCsv" asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo" asp-route-statusFilter="@Model.StatusFilter" class="btn btn-meatpro"><i class="bi bi-download me-1"></i>Export CSV</a>
    </div>

    <form method="get" class="module-toolbar mb-4">
        <div class="toolbar-group flex-grow-1 gap-2">
            <div>
                <label class="form-label small text-secondary mb-1">From</label>
                <input type="date" name="dateFrom" class="form-control" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label class="form-label small text-secondary mb-1">To</label>
                <input type="date" name="dateTo" class="form-control" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label class="form-label small text-secondary mb-1">Status</label>
                <select name="statusFilter" class="form-select">
                    <option value="">All</option>
                    <option value="Available" selected="@(Model.StatusFilter == "Available")">Available</option>
                    <option value="Low stock" selected="@(Model.StatusFilter == "Low stock")">Low Stock</option>
                    <option value="Expiring" selected="@(Model.StatusFilter == "Expiring")">Expiring</option>
                </select>
            </div>
            <div class="d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-meatpro">Apply</button>
                <a asp-action="Sales" class="btn btn-link text-decoration-none">Reset</a>
            </div>
        </div>
    </form>

    <div class="dashboard-grid mb-4">
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Saleable Items</div>
                <strong class="metric-value">@Model.TotalItems</strong>
            </div>
            <div class="metric-caption mt-1">Finished goods in stock</div>
        </div>
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Potential Revenue</div>
                <strong class="metric-value">@Model.TotalPotentialRevenue.ToString("'₱'#,##0.00")</strong>
            </div>
            <div class="metric-caption mt-1">At current unit prices</div>
        </div>
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Total Stock</div>
                <strong class="metric-value">@Model.TotalStockQuantity.ToString("N0")</strong>
            </div>
            <div class="metric-caption mt-1">Units available to sell</div>
        </div>
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Low Stock</div>
                <strong class="metric-value">@Model.LowStockCount</strong>
            </div>
            <div class="metric-caption mt-1">Below reorder level</div>
        </div>
    </div>

    <div class="table-wrap">
        <table class="table erp-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>SKU</th>
                    <th>Batch</th>
                    <th class="text-end">Stock</th>
                    <th class="text-end">Reorder</th>
                    <th class="text-end">Unit Price</th>
                    <th class="text-end">Total Value</th>
                    <th>Location</th>
                    <th>Expires</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="10" class="text-center text-secondary py-5">No saleable items found.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.ProductName</td>
                            <td>@item.SKU</td>
                            <td>@item.BatchNumber</td>
                            <td class="text-end">@item.CurrentStock.ToString("N0")</td>
                            <td class="text-end">@item.ReorderLevel.ToString("N0")</td>
                            <td class="text-end">@item.UnitPrice.ToString("'₱'#,##0.00")</td>
                            <td class="text-end">@item.TotalValue.ToString("'₱'#,##0.00")</td>
                            <td>@item.StorageLocation</td>
                            <td>@(item.ExpirationDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>
                                <span class="fw-semibold text-@(item.Status == "Available" ? "success" : item.Status == "Low stock" ? "warning" : "danger")">@item.Status</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-secondary small">Showing @Model.Items.Count records</div>
        <a asp-action="ExportSalesCsv" asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo" asp-route-statusFilter="@Model.StatusFilter" class="btn btn-outline-meatpro btn-sm"><i class="bi bi-download me-1"></i>Export CSV</a>
    </div>
</div>
