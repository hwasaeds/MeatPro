@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="module-card">
    <div class="section-title">
        <div>
            <div class="section-kicker text-dark">Reports</div>
            <h1 class="h3 mb-1">Reports & Analytics</h1>
            <p class="text-secondary mb-0">Inventory, production, and procurement reporting across the ERP.</p>
        </div>
    </div>

    <div class="dashboard-grid mb-4">
        <div class="span-4 metric-card">
            <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="metric-caption">Export Formats</span>
                        <strong class="metric-value">CSV</strong>
                    </div>
                    <div class="metric-caption mt-1">Downloadable data</div>
                </div>
                <div class="stat-icon"><i class="bi bi-download"></i></div>
            </div>
        </div>
        <div class="span-4 metric-card">
            <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="metric-caption">Report Types</span>
                        <strong class="metric-value">3</strong>
                    </div>
                    <div class="metric-caption mt-1">Inventory, Production, Procurement</div>
                </div>
                <div class="stat-icon"><i class="bi bi-graph-up"></i></div>
            </div>
        </div>
        <div class="span-4 metric-card">
            <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="metric-caption">Filters</span>
                        <strong class="metric-value">Date / Status</strong>
                    </div>
                    <div class="metric-caption mt-1">Refine your data</div>
                </div>
                <div class="stat-icon"><i class="bi bi-funnel"></i></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="page-card p-4 h-100 text-center">
                <i class="bi bi-box-seam" style="font-size:2.5rem;"></i>
                <h5 class="mt-3">Inventory Report</h5>
                <p class="text-secondary small">Stock levels, movements, reorder analysis, and expiration tracking</p>
                <a asp-action="Inventory" class="btn btn-meatpro w-100"><i class="bi bi-eye me-1"></i>View Report</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="page-card p-4 h-100 text-center">
                <i class="bi bi-clipboard2-data" style="font-size:2.5rem;"></i>
                <h5 class="mt-3">Production Report</h5>
                <p class="text-secondary small">Output trends, yield efficiency, work order status, batch analysis</p>
                <a asp-action="Production" class="btn btn-meatpro w-100"><i class="bi bi-eye me-1"></i>View Report</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="page-card p-4 h-100 text-center">
                <i class="bi bi-truck" style="font-size:2.5rem;"></i>
                <h5 class="mt-3">Procurement Report</h5>
                <p class="text-secondary small">Supplier spend, purchase history, pending receipts, received status</p>
                <a asp-action="Procurement" class="btn btn-meatpro w-100"><i class="bi bi-eye me-1"></i>View Report</a>
            </div>
        </div>
    </div>
</div>
