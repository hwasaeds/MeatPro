@model MeatPro.ViewModels.FinishedGoodFormViewModel

<div class="page-card p-4 p-lg-5">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-lg-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Smoked Beef Sausage" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="SKU" class="form-label"></label>
                <input asp-for="SKU" class="form-control" placeholder="FG-001" />
                <span asp-validation-for="SKU" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="BatchNumber" class="form-label"></label>
                <input asp-for="BatchNumber" class="form-control" placeholder="BAT-1001" />
                <span asp-validation-for="BatchNumber" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="CurrentStock" class="form-label"></label>
                <input asp-for="CurrentStock" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="CurrentStock" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="ReorderLevel" class="form-label"></label>
                <input asp-for="ReorderLevel" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="ReorderLevel" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="UnitPrice" class="form-label"></label>
                <input asp-for="UnitPrice" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="UnitPrice" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="StorageLocation" class="form-label"></label>
                <input asp-for="StorageLocation" class="form-control" placeholder="FG A1" />
                <span asp-validation-for="StorageLocation" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="ExpirationDate" class="form-label"></label>
                <input asp-for="ExpirationDate" type="date" class="form-control" />
                <span asp-validation-for="ExpirationDate" class="text-danger small"></span>
            </div>
            <div class="col-lg-6 d-flex align-items-end">
                <div class="form-check form-switch fs-6 mb-1">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>
            </div>
        </div>
</div>
