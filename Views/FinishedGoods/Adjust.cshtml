@model MeatPro.ViewModels.FinishedGoodAdjustmentViewModel
@{
    ViewData["Title"] = "Adjust Stock";
}

<div class="module-card">
    <div class="section-title">
        <div>
            <div class="section-kicker text-dark">Inventory</div>
            <h1 class="h3 mb-1">Adjust Stock: @Model.FinishedGoodName</h1>
            <p class="text-secondary mb-0">Set the stock quantity directly. Current: @Model.CurrentStock</p>
        </div>
        <a asp-action="Details" asp-route-id="@Model.FinishedGoodId" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>

    <form method="post" class="page-card p-4 p-lg-5">
        <input type="hidden" asp-for="FinishedGoodId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-lg-6">
                <label asp-for="NewQuantity" class="form-label"></label>
                <input asp-for="NewQuantity" class="form-control" />
                <span asp-validation-for="NewQuantity" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="Reason" class="form-label"></label>
                <input asp-for="Reason" class="form-control" placeholder="Count adjustment, damage, write-off" />
                <span asp-validation-for="Reason" class="text-danger small"></span>
            </div>
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-meatpro"><i class="bi bi-check-lg me-1"></i>Save Adjustment</button>
            <a asp-action="Details" asp-route-id="@Model.FinishedGoodId" class="btn btn-outline-meatpro ms-2">Cancel</a>
        </div>
    </form>
</div>
