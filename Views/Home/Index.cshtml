@{
    Layout = null;
    ViewData["Title"] = "MeatPro ERP";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .lp {
            min-height: 100vh;
            background: #fafaf9;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            color: #0f172a;
            overflow-x: hidden;
        }

        .lp ::selection { background: #8b0000; color: #fff; }

        .lp-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 2rem;
            max-width: 1280px;
            margin: 0 auto;
            width: 100%;
        }

        .lp-brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: inherit;
        }

        .lp-brand .mark {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: #8b0000;
            color: #fff;
            display: grid;
            place-items: center;
            font-weight: 800;
            font-size: 0.85rem;
            letter-spacing: 0.06em;
            box-shadow: 0 4px 12px rgba(139, 0, 0, 0.25);
        }

        .lp-brand .name { font-weight: 700; font-size: 1rem; line-height: 1.2; }
        .lp-brand .sub { font-size: 0.7rem; color: #94a3b8; letter-spacing: 0.03em; }

        .lp-header-actions { display: flex; align-items: center; gap: 0.75rem; }

        .lp-btn-primary {
            padding: 0.55rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.875rem;
            background: #8b0000;
            color: #fff;
            border: 0;
            text-decoration: none;
            transition: all 0.2s ease;
            box-shadow: 0 4px 14px rgba(139, 0, 0, 0.25);
        }
        .lp-btn-primary:hover { background: #a30000; color: #fff; box-shadow: 0 6px 20px rgba(139, 0, 0, 0.35); transform: translateY(-1px); }

        .lp-btn-ghost {
            padding: 0.55rem 1.25rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.875rem;
            background: transparent;
            color: #475569;
            border: 1px solid #e2e8f0;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        .lp-btn-ghost:hover { background: #f1f5f9; border-color: #cbd5e1; color: #0f172a; }

        .lp-hero {
            display: flex;
            align-items: center;
            justify-content: space-between;
            max-width: 1280px;
            margin: 0 auto;
            padding: 5rem 2rem 3rem;
            gap: 4rem;
        }

        .lp-hero-text { flex: 1; max-width: 560px; }

        .lp-hero-text .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.3rem 0.8rem;
            border-radius: 40px;
            background: #fef2f2;
            color: #991b1b;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            border: 1px solid rgba(139, 0, 0, 0.1);
            margin-bottom: 1.25rem;
        }

        .lp-hero-text h1 {
            font-size: clamp(2.5rem, 5vw, 3.8rem);
            font-weight: 900;
            letter-spacing: -0.04em;
            line-height: 1.05;
            margin-bottom: 1.25rem;
            color: #0f172a;
        }

        .lp-hero-text h1 .highlight { color: #8b0000; }

        .lp-hero-text p {
            font-size: 1.05rem;
            color: #475569;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        .lp-hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

        .lp-hero-visual {
            flex: 1;
            max-width: 520px;
            position: relative;
        }

        .lp-hero-card {
            background: #fff;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
            overflow: hidden;
        }

        .lp-hero-card-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1rem;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
        }

        .lp-hero-card-header .dot { width: 8px; height: 8px; border-radius: 50%; background: #e2e8f0; }
        .lp-hero-card-header .dot.d1 { background: #ef4444; }
        .lp-hero-card-header .dot.d2 { background: #eab308; }
        .lp-hero-card-header .dot.d3 { background: #22c55e; }

        .lp-hero-card-body { padding: 1.25rem; display: grid; gap: 0.75rem; }

        .lp-hero-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.65rem 0.75rem;
            border-radius: 6px;
            background: #fafaf9;
            border: 1px solid #f1f5f9;
        }

        .lp-hero-row .label { font-size: 0.8rem; color: #64748b; font-weight: 500; display: flex; align-items: center; gap: 0.4rem; }
        .lp-hero-row .label i { color: #8b0000; font-size: 0.75rem; }
        .lp-hero-row .value { font-size: 0.85rem; font-weight: 700; color: #0f172a; }
        .lp-hero-row .badge-value {
            padding: 0.2rem 0.6rem;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
            background: #dcfce7;
            color: #166534;
        }

        .lp-logos {
            max-width: 1280px;
            margin: 0 auto;
            padding: 3rem 2rem;
            text-align: center;
        }

        .lp-logos p {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #94a3b8;
            font-weight: 600;
            margin-bottom: 1.25rem;
        }

        .lp-logos-grid {
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
            color: #94a3b8;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .lp-logos-grid span { opacity: 0.5; }

        .lp-features {
            max-width: 1280px;
            margin: 0 auto;
            padding: 3rem 2rem 4rem;
        }

        .lp-features-header { text-align: center; margin-bottom: 3rem; }

        .lp-features-header h2 {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            margin-bottom: 0.5rem;
        }

        .lp-features-header p { color: #64748b; font-size: 1rem; }

        .lp-feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1rem;
        }

        .lp-feature-card {
            padding: 1.5rem;
            border-radius: 12px;
            background: #fff;
            border: 1px solid #e2e8f0;
            transition: all 0.2s ease;
        }

        .lp-feature-card:hover {
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
            border-color: #cbd5e1;
        }

        .lp-feature-card .icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: #fef2f2;
            color: #8b0000;
            display: grid;
            place-items: center;
            font-size: 1.1rem;
            margin-bottom: 1rem;
        }

        .lp-feature-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.35rem; }
        .lp-feature-card p { font-size: 0.85rem; color: #64748b; line-height: 1.6; margin: 0; }

        .lp-cta {
            max-width: 1280px;
            margin: 0 auto;
            padding: 2rem;
            text-align: center;
        }

        .lp-cta-inner {
            background: #0f172a;
            border-radius: 20px;
            padding: 4rem 2rem;
            color: #fff;
        }

        .lp-cta-inner h2 {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            margin-bottom: 0.75rem;
        }

        .lp-cta-inner p { color: #94a3b8; margin-bottom: 1.5rem; }

        .lp-cta-inner .lp-btn-primary { box-shadow: 0 4px 20px rgba(139, 0, 0, 0.4); }

        .lp-footer {
            max-width: 1280px;
            margin: 0 auto;
            padding: 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            color: #94a3b8;
            font-size: 0.85rem;
            border-top: 1px solid #e2e8f0;
        }

        @@media (max-width: 900px) {
            .lp-hero { flex-direction: column; padding: 3rem 1.5rem 2rem; gap: 2.5rem; }
            .lp-hero-text h1 { font-size: 2.2rem; }
            .lp-hero-visual { max-width: 100%; width: 100%; }
            .lp-header { padding: 0.75rem 1rem; }
        }

        @@media (max-width: 600px) {
            .lp-hero-text h1 { font-size: 1.8rem; }
            .lp-feature-grid { grid-template-columns: 1fr; }
            .lp-cta-inner { padding: 3rem 1.5rem; }
        }
    </style>
</head>
<body class="lp">

    <header class="lp-header">
        <a asp-controller="Home" asp-action="Index" class="lp-brand">
            <div class="mark">MP</div>
            <div>
                <div class="name">MeatPro</div>
                <div class="sub">Meat Manufacturing ERP</div>
            </div>
        </a>
        <div class="lp-header-actions">
            <a asp-controller="Account" asp-action="Login" class="lp-btn-ghost">Sign in</a>
            <a asp-controller="Account" asp-action="Login" class="lp-btn-primary">Get started</a>
        </div>
    </header>

    <section class="lp-hero">
        <div class="lp-hero-text">
            <div class="eyebrow"><i class="bi bi-diamond-fill" style="font-size: 0.4rem;"></i> Built for meat processors</div>
            <h1>From <span class="highlight">raw material</span> to finished product — track it all.</h1>
            <p>MeatPro is a full-cycle ERP purpose-built for meat and protein processors. Manage inventory, production, procurement, and reporting in one place.</p>
            <div class="lp-hero-actions">
                <a asp-controller="Account" asp-action="Login" class="lp-btn-primary">
                    Get started <i class="bi bi-arrow-right ms-1"></i>
                </a>
                <a asp-controller="Account" asp-action="Login" class="lp-btn-ghost">
                    Sign in <i class="bi bi-box-arrow-in-right ms-1"></i>
                </a>
            </div>
        </div>
        <div class="lp-hero-visual">
            <div class="lp-hero-card">
                <div class="lp-hero-card-header">
                    <div class="dot d1"></div>
                    <div class="dot d2"></div>
                    <div class="dot d3"></div>
                    <span style="margin-left: auto; font-size: 0.7rem; color: #94a3b8; font-weight: 500;">Dashboard</span>
                </div>
                <div class="lp-hero-card-body">
                    <div class="lp-hero-row">
                        <span class="label"><i class="bi bi-box-seam"></i> Raw Materials</span>
                        <span class="value">24 SKUs</span>
                    </div>
                    <div class="lp-hero-row">
                        <span class="label"><i class="bi bi-clipboard2-check"></i> Active Work Orders</span>
                        <span class="badge-value">8 running</span>
                    </div>
                    <div class="lp-hero-row">
                        <span class="label"><i class="bi bi-bag-check"></i> Finished Goods</span>
                        <span class="value">12 SKUs</span>
                    </div>
                    <div class="lp-hero-row">
                        <span class="label"><i class="bi bi-truck"></i> Suppliers</span>
                        <span class="value">15 registered</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="lp-logos">
        <p>Trusted by teams across the supply chain</p>
        <div class="lp-logos-grid">
            <span>Meat Processors Inc.</span>
            <span>Prime Cuts Co.</span>
            <span>FreshPack Logistics</span>
            <span>Butcher's Block</span>
            <span>ProteinWorks</span>
        </div>
    </div>

    <section class="lp-features">
        <div class="lp-features-header">
            <h2>Everything you need to run production</h2>
            <p>Purpose-built modules that work together seamlessly.</p>
        </div>
        <div class="lp-feature-grid">
            <div class="lp-feature-card">
                <div class="icon"><i class="bi bi-box-seam"></i></div>
                <h3>Raw Materials</h3>
                <p>Track ingredients, stock levels, reorder thresholds, and supplier sources.</p>
            </div>
            <div class="lp-feature-card">
                <div class="icon"><i class="bi bi-bag-check"></i></div>
                <h3>Finished Goods</h3>
                <p>Monitor output inventory, batch numbers, expiration windows, and pricing.</p>
            </div>
            <div class="lp-feature-card">
                <div class="icon"><i class="bi bi-kanban"></i></div>
                <h3>Production Planning</h3>
                <p>Create plans, schedule work orders, and register production batches with full traceability.</p>
            </div>
            <div class="lp-feature-card">
                <div class="icon"><i class="bi bi-truck"></i></div>
                <h3>Procurement</h3>
                <p>Manage suppliers, purchase transactions, and goods receipt workflows.</p>
            </div>
            <div class="lp-feature-card">
                <div class="icon"><i class="bi bi-graph-up"></i></div>
                <h3>Reports & Analytics</h3>
                <p>Inventory valuations, production output trends, and procurement spend analysis.</p>
            </div>
            <div class="lp-feature-card">
                <div class="icon"><i class="bi bi-shield-lock"></i></div>
                <h3>Role-based Access</h3>
                <p>Fine-grained permissions for production managers, inventory staff, and administrators.</p>
            </div>
        </div>
    </section>

    <section class="lp-cta">
        <div class="lp-cta-inner">
            <h2>Ready to streamline your operations?</h2>
            <p>Get started with MeatPro and take control of your manufacturing workflow.</p>
            <a asp-controller="Account" asp-action="Login" class="lp-btn-primary" style="display: inline-flex; align-items: center; gap: 0.5rem;">
                Get started <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </section>

    <footer class="lp-footer">
        <div>&copy; @DateTime.UtcNow.Year MeatPro ERP — Meat Manufacturing System</div>

    </footer>

</body>
</html>
