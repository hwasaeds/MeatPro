@model MeatPro.ViewModels.WorkOrderDetailsViewModel
@{
    ViewData["Title"] = Model.WorkOrderNumber;
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Production</div>
            <h1 class="h3 mb-1">@Model.WorkOrderNumber</h1>
            <p class="text-secondary mb-0">@Model.PlanCode | @Model.ScheduledDate.ToString("yyyy-MM-dd")</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-meatpro"><i class="bi bi-pencil me-1"></i>Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</a>
            @if (Model.Status == "Draft")
            {
                <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Approve</button>
                </form>
            }
            @if (Model.Status == "Planned")
            {
                <form asp-action="Start" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-play-fill me-1"></i>Start Production</button>
                </form>
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Cancel this work order?');"><i class="bi bi-x-circle me-1"></i>Cancel</button>
                </form>
            }
            @if (Model.Status == "InProgress")
            {
                <form asp-action="Hold" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-warning"><i class="bi bi-pause-fill me-1"></i>Hold</button>
                </form>
                <a asp-action="Complete" asp-route-id="@Model.Id" class="btn btn-success"><i class="bi bi-check-all me-1"></i>Complete</a>
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Cancel this work order?');"><i class="bi bi-x-circle me-1"></i>Cancel</button>
                </form>
            }
            @if (Model.Status == "OnHold")
            {
                <form asp-action="Resume" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-arrow-repeat me-1"></i>Resume</button>
                </form>
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Cancel this work order?');"><i class="bi bi-x-circle me-1"></i>Cancel</button>
                </form>
            }
            <a asp-action="Index" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to list</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
    }

    <div class="dashboard-grid mb-4">
        <div class="span-3 metric-card">
            <div class="metric-caption">Status</div>
            <strong class="metric-value">@Model.Status</strong>
            <div class="metric-caption mt-1">Current state</div>
        </div>
        <div class="span-3 metric-card">
            <div class="metric-caption">Planned Quantity</div>
            <strong class="metric-value">@Model.Quantity.ToString("N0")</strong>
            <div class="metric-caption mt-1">Production target</div>
        </div>
        <div class="span-3 metric-card">
            <div class="metric-caption">Output Quantity</div>
            <strong class="metric-value">@Model.OutputQuantity.ToString("N0")</strong>
            <div class="metric-caption mt-1">Actual produced</div>
        </div>
        <div class="span-3 metric-card">
            <div class="metric-caption">Assigned To</div>
            <strong class="metric-value">@Model.AssignedTo</strong>
            <div class="metric-caption mt-1">Responsible party</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="page-card p-4 h-100">
                    <h2 class="h6 text-uppercase text-secondary mb-3">Work order details</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-secondary">Work Order #</dt>
                        <dd class="col-sm-8">@Model.WorkOrderNumber</dd>

                        <dt class="col-sm-4 text-secondary">Production Plan</dt>
                        <dd class="col-sm-8">@Model.PlanCode</dd>

                        <dt class="col-sm-4 text-secondary">Scheduled Date</dt>
                        <dd class="col-sm-8">@Model.ScheduledDate.ToString("yyyy-MM-dd")</dd>

                        <dt class="col-sm-4 text-secondary">Quantity</dt>
                        <dd class="col-sm-8">@Model.Quantity.ToString("N0")</dd>

                        <dt class="col-sm-4 text-secondary">Output Quantity</dt>
                        <dd class="col-sm-8">@Model.OutputQuantity.ToString("N0")</dd>

                        <dt class="col-sm-4 text-secondary">Assigned To</dt>
                        <dd class="col-sm-8">@Model.AssignedTo</dd>

                        <dt class="col-sm-4 text-secondary">Notes</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Notes) ? "None" : Model.Notes)</dd>

                        <dt class="col-sm-4 text-secondary">Created</dt>
                        <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>

                        <dt class="col-sm-4 text-secondary">Updated</dt>
                        <dd class="col-sm-8">@(Model.UpdatedAtUtc is null ? "Never" : Model.UpdatedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") + " UTC")</dd>
                    </dl>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-card p-4 h-100">
                    <h2 class="h6 text-uppercase text-secondary mb-3">Status</h2>
                    <span class="badge text-bg-@Model.StatusTone mb-3">@Model.Status</span>
                    <p class="text-secondary mb-3">This work order is currently <strong>@Model.Status</strong>.</p>

                    @if (Model.Status == "Draft")
                    {
                        <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="mb-2">
                            <button type="submit" class="btn btn-success w-100"><i class="bi bi-check-circle me-1"></i>Approve</button>
                        </form>
                    }
                    @if (Model.Status == "Planned")
                    {
                        <form asp-action="Start" asp-route-id="@Model.Id" method="post" class="mb-2">
                            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-play-fill me-1"></i>Start Production</button>
                        </form>
                    }
                    @if (Model.Status == "InProgress")
                    {
                        <form asp-action="Hold" asp-route-id="@Model.Id" method="post" class="mb-2">
                            <button type="submit" class="btn btn-warning w-100"><i class="bi bi-pause-fill me-1"></i>Hold</button>
                        </form>
                        <a asp-action="Complete" asp-route-id="@Model.Id" class="btn btn-success w-100 mb-2"><i class="bi bi-check-all me-1"></i>Complete</a>
                    }
                    @if (Model.Status == "OnHold")
                    {
                        <form asp-action="Resume" asp-route-id="@Model.Id" method="post" class="mb-2">
                            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-arrow-repeat me-1"></i>Resume</button>
                        </form>
                    }

                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-meatpro w-100 mb-2"><i class="bi bi-pencil me-1"></i>Edit Work Order</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger w-100"><i class="bi bi-trash me-1"></i>Delete Work Order</a>
            </div>
        </div>
    </div>
</div>
