@model MeatPro.ViewModels.CompleteWorkOrderViewModel
@{
    ViewData["Title"] = "Complete Work Order";
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Production</div>
            <h1 class="h3 mb-1">Complete Work Order</h1>
            <p class="text-secondary mb-0">Record the production output and create a batch.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to list</a>
    </div>

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger border-0 shadow-sm">@errorMessage</div>
    }

    <form asp-action="Complete" method="post" class="vstack gap-4">
        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="ProducedQuantity" class="form-label"></label>
                <input asp-for="ProducedQuantity" class="form-control" />
                <span asp-validation-for="ProducedQuantity" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="BatchNumber" class="form-label"></label>
                <input asp-for="BatchNumber" class="form-control" />
                <span asp-validation-for="BatchNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ProducedAt" class="form-label"></label>
                <input asp-for="ProducedAt" class="form-control" type="date" />
                <span asp-validation-for="ProducedAt" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="RawMaterialConsumed" class="form-label"></label>
                <input asp-for="RawMaterialConsumed" class="form-control" />
                <span asp-validation-for="RawMaterialConsumed" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ExpirationDate" class="form-label"></label>
                <input asp-for="ExpirationDate" class="form-control" type="date" />
                <span asp-validation-for="ExpirationDate" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <a asp-action="Index" class="btn btn-outline-meatpro"><i class="bi bi-x-lg me-1"></i>Cancel</a>
            <button type="submit" class="btn btn-success"><i class="bi bi-check-all me-1"></i>Complete Work Order</button>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
