@model MeatPro.ViewModels.RawMaterialFormViewModel

<div class="page-card p-4 p-lg-5">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-lg-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Beef Trim" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="SKU" class="form-label"></label>
                <input asp-for="SKU" class="form-control" placeholder="RM-001" />
                <span asp-validation-for="SKU" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="UnitOfMeasure" class="form-label"></label>
                <input asp-for="UnitOfMeasure" class="form-control" placeholder="kg" />
                <span asp-validation-for="UnitOfMeasure" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="CurrentStock" class="form-label"></label>
                <input asp-for="CurrentStock" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="CurrentStock" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="ReorderLevel" class="form-label"></label>
                <input asp-for="ReorderLevel" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="ReorderLevel" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="UnitCost" class="form-label"></label>
                <input asp-for="UnitCost" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="UnitCost" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="Location" class="form-label"></label>
                <input asp-for="Location" class="form-control" placeholder="Cold Room A" />
                <span asp-validation-for="Location" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="SupplierName" class="form-label"></label>
                <input asp-for="SupplierName" class="form-control" placeholder="North Farm Ltd" />
                <span asp-validation-for="SupplierName" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="ExpirationDate" class="form-label"></label>
                <input asp-for="ExpirationDate" type="date" class="form-control" />
                <span asp-validation-for="ExpirationDate" class="text-danger small"></span>
            </div>
            <div class="col-lg-6 d-flex align-items-end">
                <div class="form-check form-switch fs-6 mb-1">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>
            </div>
        </div>
</div>
