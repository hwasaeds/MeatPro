@model MeatPro.ViewModels.PurchaseTransactionFormViewModel

<div class="page-card p-4 p-lg-5">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-lg-6">
                <label asp-for="PurchaseNumber" class="form-label"></label>
                <input asp-for="PurchaseNumber" class="form-control" placeholder="PO-2026-0001" />
                <span asp-validation-for="PurchaseNumber" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="SupplierId" class="form-label"></label>
                <select asp-for="SupplierId" asp-items="@(new SelectList(Model.Suppliers, "Id", "Name"))" class="form-select">
                    <option value="">-- Select supplier --</option>
                </select>
                <span asp-validation-for="SupplierId" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="PurchasedOn" class="form-label"></label>
                <input asp-for="PurchasedOn" type="date" class="form-control" />
                <span asp-validation-for="PurchasedOn" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="TotalAmount" class="form-label"></label>
                <input asp-for="TotalAmount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                <span asp-validation-for="TotalAmount" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="@(new SelectList(Enum.GetValues<PurchaseStatus>()))" class="form-select"></select>
                <span asp-validation-for="Status" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="ReceivedOn" class="form-label"></label>
                <input asp-for="ReceivedOn" type="date" class="form-control" />
                <span asp-validation-for="ReceivedOn" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Weekly beef procurement"></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>
        </div>
</div>
