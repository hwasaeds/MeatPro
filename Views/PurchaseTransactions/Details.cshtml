@model MeatPro.ViewModels.PurchaseTransactionDetailsViewModel
@{
    ViewData["Title"] = Model.PurchaseNumber;
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Procurement</div>
            <h1 class="h3 mb-1">@Model.PurchaseNumber</h1>
            <p class="text-secondary mb-0">@Model.SupplierName | @Model.PurchasedOn.ToString("yyyy-MM-dd")</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-meatpro"><i class="bi bi-pencil me-1"></i>Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</a>
            <a asp-action="Index" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to list</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
    }

    <div class="dashboard-grid mb-4">
        <div class="span-3 metric-card">
            <div class="metric-caption">Status</div>
            <strong class="metric-value">@Model.Status</strong>
            <div class="metric-caption mt-1">Current state</div>
        </div>
        <div class="span-3 metric-card">
            <div class="metric-caption">Total Amount</div>
            <strong class="metric-value">@Model.TotalAmount.ToString("C")</strong>
            <div class="metric-caption mt-1">Procurement value</div>
        </div>
        <div class="span-3 metric-card">
            <div class="metric-caption">Supplier</div>
            <strong class="metric-value">@Model.SupplierName</strong>
            <div class="metric-caption mt-1">Vendor</div>
        </div>
        <div class="span-3 metric-card">
            <div class="metric-caption">Received</div>
            <strong class="metric-value">@(Model.ReceivedOn?.ToString("yyyy-MM-dd") ?? "Not yet received")</strong>
            <div class="metric-caption mt-1">Goods receipt date</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="page-card p-4 h-100">
                    <h2 class="h6 text-uppercase text-secondary mb-3">Purchase details</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-secondary">Purchase Number</dt>
                        <dd class="col-sm-8">@Model.PurchaseNumber</dd>

                        <dt class="col-sm-4 text-secondary">Supplier</dt>
                        <dd class="col-sm-8">@Model.SupplierName</dd>

                        <dt class="col-sm-4 text-secondary">Purchase Date</dt>
                        <dd class="col-sm-8">@Model.PurchasedOn.ToString("yyyy-MM-dd")</dd>

                        <dt class="col-sm-4 text-secondary">Total Amount</dt>
                        <dd class="col-sm-8">@Model.TotalAmount.ToString("C")</dd>

                        <dt class="col-sm-4 text-secondary">Received On</dt>
                        <dd class="col-sm-8">@(Model.ReceivedOn?.ToString("yyyy-MM-dd") ?? "Not yet received")</dd>

                        <dt class="col-sm-4 text-secondary">Notes</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Notes) ? "None" : Model.Notes)</dd>

                        <dt class="col-sm-4 text-secondary">Created</dt>
                        <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>

                        <dt class="col-sm-4 text-secondary">Updated</dt>
                        <dd class="col-sm-8">@(Model.UpdatedAtUtc is null ? "Never" : Model.UpdatedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") + " UTC")</dd>
                    </dl>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-card p-4 h-100">
                    <h2 class="h6 text-uppercase text-secondary mb-3">Status</h2>
                    <span class="badge text-bg-@Model.StatusTone mb-3">@Model.Status</span>
                    <p class="text-secondary mb-3">This purchase is currently in <strong>@Model.Status</strong> status.</p>
                    @if (Model.Status != "Received" && Model.Status != "Cancelled")
                    {
                        <a asp-action="Receive" asp-route-id="@Model.Id" class="btn btn-success w-100 mb-3"><i class="bi bi-inbox me-1"></i>Mark as Received</a>
                        <hr />
                    }
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-meatpro w-100 mb-2"><i class="bi bi-pencil me-1"></i>Edit Purchase</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger w-100"><i class="bi bi-trash me-1"></i>Delete Purchase</a>
            </div>
        </div>
    </div>
</div>
