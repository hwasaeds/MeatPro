@model MeatPro.ViewModels.SupplierDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Procurement</div>
            <h1 class="h3 mb-1">@Model.Name</h1>
            <p class="text-secondary mb-0">@Model.ContactPerson | @Model.Phone</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-meatpro"><i class="bi bi-pencil me-1"></i>Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</a>
            <a asp-action="Index" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to list</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
    }

    <div class="dashboard-grid mb-4">
        <div class="span-4 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Status</div>
                <strong class="metric-value">@Model.Status</strong>
            </div>
            <div class="metric-caption mt-1">Current state</div>
        </div>
        <div class="span-4 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Contact Person</div>
                <strong class="metric-value">@Model.ContactPerson</strong>
            </div>
            <div class="metric-caption mt-1">Primary contact</div>
        </div>
        <div class="span-4 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Phone</div>
                <strong class="metric-value">@Model.Phone</strong>
            </div>
            <div class="metric-caption mt-1">Contact number</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="page-card p-4 h-100">
                    <h2 class="h6 text-uppercase text-secondary mb-3">Supplier details</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-secondary">Name</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4 text-secondary">Contact Person</dt>
                        <dd class="col-sm-8">@Model.ContactPerson</dd>

                        <dt class="col-sm-4 text-secondary">Phone</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>

                        <dt class="col-sm-4 text-secondary">Email</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4 text-secondary">Address</dt>
                        <dd class="col-sm-8">@Model.Address</dd>

                        <dt class="col-sm-4 text-secondary">Created</dt>
                        <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>

                        <dt class="col-sm-4 text-secondary">Updated</dt>
                        <dd class="col-sm-8">@(Model.UpdatedAtUtc is null ? "Never" : Model.UpdatedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") + " UTC")</dd>
                    </dl>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-card p-4 h-100">
                    <h2 class="h6 text-uppercase text-secondary mb-3">Status</h2>
                    <span class="fw-semibold text-@Model.StatusTone mb-3">@Model.Status</span>
                    <p class="text-secondary mb-3">This supplier is currently @(Model.IsActive ? "active and available for procurement." : "inactive and unavailable for new purchases.")</p>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-meatpro w-100 mb-2"><i class="bi bi-pencil me-1"></i>Edit Supplier</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger w-100"><i class="bi bi-trash me-1"></i>Delete Supplier</a>
            </div>
        </div>
    </div>
</div>
