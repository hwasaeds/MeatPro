@model MeatPro.ViewModels.SupplierDetailsViewModel
@{
    ViewData["Title"] = "Delete Supplier";
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Procurement</div>
            <h1 class="h3 mb-1">Delete Supplier</h1>
            <p class="text-secondary mb-0">This action removes the vendor from the supplier register.</p>
        </div>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to details</a>
    </div>

    <div class="alert alert-warning">
        Deleting <strong>@Model.Name</strong> will remove the record permanently.
    </div>

    <div class="page-card p-3 mb-4">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-secondary">Contact Person</dt>
                <dd class="col-sm-8">@Model.ContactPerson</dd>

                <dt class="col-sm-4 text-secondary">Phone</dt>
                <dd class="col-sm-8">@Model.Phone</dd>

                <dt class="col-sm-4 text-secondary">Email</dt>
                <dd class="col-sm-8">@Model.Email</dd>

                <dt class="col-sm-4 text-secondary">Status</dt>
                <dd class="col-sm-8"><span class="badge text-bg-@Model.StatusTone">@Model.Status</span></dd>
            </dl>
    </div>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex justify-content-center gap-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-meatpro"><i class="bi bi-x-lg me-1"></i>Cancel</a>
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete Supplier</button>
    </form>
</div>
