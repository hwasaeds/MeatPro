@model MeatPro.ViewModels.ProductFormViewModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker">Products</div>
            <h1 class="h4 fw-bold mb-1">Edit Product</h1>
            <p class="text-secondary mb-0" style="font-size:0.875rem;">Update product details, pricing, or category.</p>
        </div>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="vstack gap-4">
        <partial name="_Form" model="Model" />
        <div class="d-flex justify-content-end gap-2">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-meatpro"><i class="bi bi-x-lg me-1"></i>Cancel</a>
            <button type="submit" class="btn btn-meatpro"><i class="bi bi-check-lg me-1"></i>Update Product</button>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
