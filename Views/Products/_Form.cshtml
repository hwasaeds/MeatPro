@model MeatPro.ViewModels.ProductFormViewModel

<div class="page-card p-4 p-lg-5">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-lg-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Premium Beef Sausage" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="SKU" class="form-label"></label>
                <input asp-for="SKU" class="form-control" placeholder="PRD-001" />
                <span asp-validation-for="SKU" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="ProductCategoryId" class="form-label"></label>
                <select asp-for="ProductCategoryId" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))" class="form-select">
                    <option value="">-- Select category --</option>
                </select>
                <span asp-validation-for="ProductCategoryId" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="UnitOfMeasure" class="form-label"></label>
                <input asp-for="UnitOfMeasure" class="form-control" placeholder="kg" />
                <span asp-validation-for="UnitOfMeasure" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="SellingPrice" class="form-label"></label>
                <input asp-for="SellingPrice" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="SellingPrice" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="StandardYield" class="form-label"></label>
                <input asp-for="StandardYield" type="number" step="0.01" class="form-control" placeholder="0.92" />
                <span asp-validation-for="StandardYield" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="ReorderLevel" class="form-label"></label>
                <input asp-for="ReorderLevel" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="ReorderLevel" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="2" placeholder="Smoked sausage pack"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="col-lg-6 d-flex align-items-end">
                <div class="form-check form-switch fs-6 mb-1">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>
            </div>
        </div>
</div>
