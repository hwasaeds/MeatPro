@model MeatPro.ViewModels.NotificationIndexViewModel
@using MeatPro.Models
@{
    ViewData["Title"] = "Notifications Center";
    var startPage = Math.Max(1, Model.Page - 2);
    var endPage = Math.Min(Model.TotalPages, startPage + 4);
    if (endPage - startPage < 4) { startPage = Math.Max(1, endPage - 4); }
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">System</div>
            <h1 class="h3 mb-1">Notifications Center</h1>
            <p class="text-secondary mb-0">View and manage system alerts and notifications.</p>
        </div>
        <div class="d-flex gap-2">
            <form asp-action="ReadAll" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-meatpro"><i class="bi bi-check2-all me-1"></i>Mark All Read</button>
            </form>
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-meatpro"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
    }

    <form method="get" class="module-toolbar mb-4">
        <div class="toolbar-group">
            <select name="type" class="form-select" style="max-width:200px">
                <option value="">All Types</option>
                <option value="Info" selected="@(Model.TypeFilter == "Info")">Info</option>
                <option value="Success" selected="@(Model.TypeFilter == "Success")">Success</option>
                <option value="Warning" selected="@(Model.TypeFilter == "Warning")">Warning</option>
                <option value="Danger" selected="@(Model.TypeFilter == "Danger")">Danger</option>
            </select>
            <button type="submit" class="btn btn-outline-meatpro">Filter</button>
            <a asp-action="Index" class="btn btn-link text-decoration-none">Reset</a>
        </div>
    </form>

    <div class="vstack gap-2">
        @if (Model.Items.Count == 0)
        {
            <div class="text-center text-secondary py-5">
                <i class="bi bi-bell-slash" style="font-size:2rem;"></i>
                <p class="mt-2 mb-0">No notifications found.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <div class="page-card p-3 @(item.IsRead ? "" : "border-start border-3 border-primary")">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge text-bg-@(item.Type == NotificationType.Danger ? "danger" : item.Type == NotificationType.Warning ? "warning" : item.Type == NotificationType.Success ? "success" : "info")">@item.Type</span>
                                <strong>@item.Title</strong>
                                @if (!item.IsRead)
                                {
                                    <span class="badge bg-primary" style="font-size:0.55rem;">NEW</span>
                                }
                            </div>
                            <p class="mb-0 text-secondary">@item.Message</p>
                            <small class="text-secondary">@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</small>
                        </div>
                        <form asp-action="Dismiss" asp-route-id="@item.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Dismiss"><i class="bi bi-x-lg"></i></button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-3">
            <div class="text-secondary small">Showing @Model.Items.Count of @Model.TotalItems notifications</div>
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div class="text-secondary small">Page @Model.Page of @Model.TotalPages</div>
                <nav aria-label="Notifications pagination">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-type="@Model.TypeFilter" asp-route-page="@(Model.Page - 1)"><i class="bi bi-chevron-left"></i></a>
                        </li>
                        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-type="@Model.TypeFilter" asp-route-page="@(pageNumber)">@pageNumber</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-type="@Model.TypeFilter" asp-route-page="@(Model.Page + 1)"><i class="bi bi-chevron-right"></i></a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>
