@model MeatPro.ViewModels.DashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
}

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <div class="section-kicker">Overview</div>
        <h1 class="h4 fw-bold mb-0 mt-1">Dashboard</h1>
    </div>
    <form method="get" asp-controller="Dashboard" asp-action="Index" class="d-flex align-items-center gap-2 flex-wrap">
        <label class="text-secondary small mb-0">From</label>
        <input type="date" name="fromDate" class="form-control form-control-sm" value="@Model.FromDate?.ToString("yyyy-MM-dd")" style="max-width:160px" />
        <label class="text-secondary small mb-0">To</label>
        <input type="date" name="toDate" class="form-control form-control-sm" value="@Model.ToDate?.ToString("yyyy-MM-dd")" style="max-width:160px" />
        <button type="submit" class="btn btn-sm btn-outline-meatpro">Filter</button>
        <a asp-action="Index" class="btn btn-sm btn-outline-meatpro">Reset</a>
    </form>
</div>

<div class="dashboard-grid">
    @foreach (var card in Model.MetricCards)
    {
        <div class="span-4 stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon flex-shrink-0"><i class="bi @card.Icon"></i></div>
                <div class="flex-grow-1 min-w-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="metric-caption">@card.Title</span>
                        <strong class="metric-value fs-3">@card.Value</strong>
                    </div>
                    <div class="metric-caption mt-1">@card.Caption</div>
                </div>
            </div>
        </div>
    }

    <div class="span-7 dashboard-chart">
        <div class="section-title">
            <div>
                <div class="section-kicker">Production</div>
                <h5 class="mb-0 fw-semibold">Production output trend</h5>
            </div>
        </div>
        <div class="chart-wrap"><canvas id="productionOutputChart"></canvas></div>
    </div>

    <div class="span-5 dashboard-chart">
        <div class="section-title">
            <div>
                <div class="section-kicker">Inventory</div>
                <h5 class="mb-0 fw-semibold">Inventory movement</h5>
            </div>
        </div>
        <div class="chart-wrap"><canvas id="inventoryMovementChart"></canvas></div>
    </div>

    <div class="span-6 dashboard-chart">
        <div class="section-title">
            <div>
                <div class="section-kicker">Products</div>
                <h5 class="mb-0 fw-semibold">Top produced products</h5>
            </div>
        </div>
        <div class="chart-wrap"><canvas id="topProductsChart"></canvas></div>
    </div>

    <div class="span-6 dashboard-chart">
        <div class="section-title">
            <div>
                <div class="section-kicker">Materials</div>
                <h5 class="mb-0 fw-semibold">Consumption analysis</h5>
            </div>
        </div>
        <div class="chart-wrap"><canvas id="materialConsumptionChart"></canvas></div>
    </div>

    <div class="span-12 dashboard-chart">
        <div class="section-title">
            <div>
                <div class="section-kicker">Activity</div>
                <h5 class="mb-0 fw-semibold">Recent operations</h5>
            </div>
        </div>
        <div class="activity-list">
            @foreach (var item in Model.RecentActivities)
            {
                <div class="activity-item">
                    <div>
                        <div class="fw-semibold small">@item.Title</div>
                        <span class="text-secondary" style="font-size:0.8rem;">@item.Description</span>
                    </div>
                    <div class="text-end">
                        <span class="fw-semibold text-@item.BadgeTone small">@item.Badge</span>
                        <div class="metric-caption mt-1">@item.TimeAgo</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
    (function() {
        var data = {
            production: {
                labels: @Html.Raw(JsonSerializer.Serialize(Model.ProductionOutputTrend.Labels)),
                values: @Html.Raw(JsonSerializer.Serialize(Model.ProductionOutputTrend.Values))
            },
            inventory: {
                labels: @Html.Raw(JsonSerializer.Serialize(Model.InventoryMovementChart.Labels)),
                values: @Html.Raw(JsonSerializer.Serialize(Model.InventoryMovementChart.Values))
            },
            topProducts: {
                labels: @Html.Raw(JsonSerializer.Serialize(Model.TopProducedProducts.Labels)),
                values: @Html.Raw(JsonSerializer.Serialize(Model.TopProducedProducts.Values))
            },
            consumption: {
                labels: @Html.Raw(JsonSerializer.Serialize(Model.MaterialConsumption.Labels)),
                values: @Html.Raw(JsonSerializer.Serialize(Model.MaterialConsumption.Values))
            }
        };

        var colors = {
            primary: '#8b0000',
            success: '#22c55e',
            warning: '#d4af37',
            danger: '#ef4444',
            info: '#06b6d4'
        };

        var baseOpts = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { labels: { usePointStyle: true, boxWidth: 8, padding: 16 } } }
        };

        new Chart(document.getElementById('productionOutputChart'), {
            type: 'bar',
            data: {
                labels: data.production.labels,
                datasets: [{
                    label: 'Output',
                    data: data.production.values,
                    backgroundColor: colors.primary + '22',
                    borderColor: colors.primary,
                    borderWidth: 2,
                    borderRadius: 4
                }]
            },
            options: Object.assign({}, baseOpts, {
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
            })
        });

        new Chart(document.getElementById('inventoryMovementChart'), {
            type: 'doughnut',
            data: {
                labels: data.inventory.labels,
                datasets: [{
                    data: data.inventory.values,
                    backgroundColor: [colors.success + 'cc', colors.danger + 'cc', colors.warning + 'cc', colors.info + 'cc'],
                    borderWidth: 0
                }]
            },
            options: Object.assign({}, baseOpts, {
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 16 } } }
            })
        });

        new Chart(document.getElementById('topProductsChart'), {
            type: 'bar',
            data: {
                labels: data.topProducts.labels,
                datasets: [{
                    label: 'Units produced',
                    data: data.topProducts.values,
                    backgroundColor: colors.success + '22',
                    borderColor: colors.success,
                    borderWidth: 2,
                    borderRadius: 4
                }]
            },
            options: Object.assign({}, baseOpts, {
                indexAxis: 'y',
                plugins: { legend: { display: false } },
                scales: { x: { beginAtZero: true, grid: { color: '#f1f5f9' } }, y: { grid: { display: false } } }
            })
        });

        new Chart(document.getElementById('materialConsumptionChart'), {
            type: 'line',
            data: {
                labels: data.consumption.labels,
                datasets: [{
                    label: 'Consumed',
                    data: data.consumption.values,
                    backgroundColor: colors.warning + '22',
                    borderColor: colors.warning,
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 3
                }]
            },
            options: Object.assign({}, baseOpts, {
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
            })
        });
    })();
</script>
}
