<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MeatPro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    }
    <div class="app-shell">
        <aside class="sidebar">
            <div class="brand-block">
                <div class="brand-mark">MP</div>
                <div>
                    <div class="brand-name">MeatPro</div>
                    <div class="brand-subtitle">Meat Manufacturing ERP</div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link @(currentController == "Dashboard" ? "active" : "")"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
                <div class="nav-group-title">Inventory</div>
                <a asp-controller="RawMaterials" asp-action="Index" class="nav-link @(currentController == "RawMaterials" ? "active" : "")"><i class="bi bi-box-seam"></i><span>Raw Materials</span></a>
                <a asp-controller="FinishedGoods" asp-action="Index" class="nav-link @(currentController == "FinishedGoods" ? "active" : "")"><i class="bi bi-bag-check"></i><span>Finished Goods</span></a>
                <a asp-controller="Inventory" asp-action="StockMovements" class="nav-link @(currentController == "Inventory" ? "active" : "")"><i class="bi bi-arrow-left-right"></i><span>Stock Movements</span></a>
                <div class="nav-group-title">Products</div>
                <a asp-controller="Products" asp-action="Index" class="nav-link @(currentController == "Products" ? "active" : "")"><i class="bi bi-box"></i><span>Products</span></a>
                <div class="nav-group-title">Production</div>
                <a asp-controller="ProductionPlans" asp-action="Index" class="nav-link @(currentController == "ProductionPlans" ? "active" : "")"><i class="bi bi-kanban"></i><span>Production Plans</span></a>
                <a asp-controller="WorkOrders" asp-action="Index" class="nav-link @(currentController == "WorkOrders" ? "active" : "")"><i class="bi bi-clipboard2-check"></i><span>Work Orders</span></a>
                <a asp-controller="ProductionBatches" asp-action="Index" class="nav-link @(currentController == "ProductionBatches" ? "active" : "")"><i class="bi bi-qr-code-scan"></i><span>Batch Traceability</span></a>
                <div class="nav-group-title">Procurement</div>
                <a asp-controller="Suppliers" asp-action="Index" class="nav-link @(currentController == "Suppliers" ? "active" : "")"><i class="bi bi-truck"></i><span>Suppliers</span></a>
                <a asp-controller="PurchaseTransactions" asp-action="Index" class="nav-link @(currentController == "PurchaseTransactions" ? "active" : "")"><i class="bi bi-receipt"></i><span>Purchase Transactions</span></a>
                <div class="nav-group-title">Reports</div>
                <a asp-controller="Reports" asp-action="Index" class="nav-link @(currentController == "Reports" ? "active" : "")"><i class="bi bi-graph-up"></i><span>Reports</span></a>
                <div class="nav-group-title">Administration</div>
                <a asp-controller="Administration" asp-action="UserIndex" class="nav-link @(currentController == "Administration" ? "active" : "")"><i class="bi bi-people"></i><span>Users</span></a>
                <a asp-controller="Administration" asp-action="RoleIndex" class="nav-link @(currentController == "Administration" ? "active" : "")"><i class="bi bi-shield-lock"></i><span>Roles</span></a>
                <a asp-controller="Administration" asp-action="Settings" class="nav-link @(currentController == "Administration" ? "active" : "")"><i class="bi bi-gear"></i><span>Settings</span></a>
                <a asp-controller="Notifications" asp-action="Index" class="nav-link @(currentController == "Notifications" ? "active" : "")"><i class="bi bi-bell"></i><span>Notifications</span></a>
                <a asp-controller="AuditLog" asp-action="Index" class="nav-link @(currentController == "AuditLog" ? "active" : "")"><i class="bi bi-journal-text"></i><span>Audit Log</span></a>
            </nav>
        </aside>

        <div class="main-panel">
            <header class="topbar">
                <button class="sidebar-toggle" type="button" data-sidebar-toggle><i class="bi bi-list"></i></button>
                <div class="search-shell">
                    <i class="bi bi-search"></i>
                    <input type="search" class="form-control" placeholder="Search materials, products, suppliers, work orders..." />
                </div>
                <div class="topbar-actions">
                    <div class="dropdown">
                        <button class="icon-chip" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-bell"></i>
                            @if (ViewBag.AlertCount is int alertCount && alertCount > 0)
                            {
                                <span class="badge rounded-pill bg-danger" style="font-size:0.6rem;padding:0.25rem 0.4rem;position:absolute;top:2px;right:2px;">@alertCount</span>
                            }
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-2" style="min-width:320px;">
                            @if (ViewBag.ActiveAlerts is IReadOnlyList<MeatPro.Models.NotificationItem> alerts && alerts.Count > 0)
                            {
                                foreach (var alert in alerts)
                                {
                                    <div class="px-2 py-2 border-bottom small">
                                        <strong class="d-block">@alert.Title</strong>
                                        <span class="text-secondary">@alert.Message</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="px-2 py-2 text-secondary small">No new alerts.</div>
                            }
                        </div>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-meatpro btn-sm">Logout</button>
                    </form>
                </div>
            </header>

            <main class="content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
