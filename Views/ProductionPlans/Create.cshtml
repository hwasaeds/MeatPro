@model MeatPro.ViewModels.ProductionPlanFormViewModel
@{
    ViewData["Title"] = "New Production Plan";
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Production</div>
            <h1 class="h3 mb-1">Create Production Plan</h1>
            <p class="text-secondary mb-0">Schedule a new production plan with targets and timelines.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to list</a>
    </div>

    <form asp-action="Create" method="post" class="vstack gap-4">
        <partial name="_Form" model="Model" />
        <div class="d-flex justify-content-end gap-2">
            <a asp-action="Index" class="btn btn-outline-meatpro"><i class="bi bi-x-lg me-1"></i>Cancel</a>
            <button type="submit" class="btn btn-meatpro"><i class="bi bi-check-lg me-1"></i>Save Plan</button>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
