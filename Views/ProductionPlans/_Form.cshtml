@model MeatPro.ViewModels.ProductionPlanFormViewModel

<div class="page-card p-4 p-lg-5">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-lg-6">
                <label asp-for="PlanCode" class="form-label"></label>
                <input asp-for="PlanCode" class="form-control" placeholder="PLAN-2026-001" />
                <span asp-validation-for="PlanCode" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="ProductId" class="form-label"></label>
                <select asp-for="ProductId" asp-items="@(new SelectList(Model.Products, "Id", "Name"))" class="form-select">
                    <option value="">-- Select product --</option>
                </select>
                <span asp-validation-for="ProductId" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="PlannedQuantity" class="form-label"></label>
                <input asp-for="PlannedQuantity" type="number" step="0.01" class="form-control" placeholder="500" />
                <span asp-validation-for="PlannedQuantity" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="StartDate" class="form-label"></label>
                <input asp-for="StartDate" type="date" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="EndDate" class="form-label"></label>
                <input asp-for="EndDate" type="date" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="@(new SelectList(Enum.GetValues<ProductionPlanStatus>()))" class="form-select"></select>
                <span asp-validation-for="Status" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="CreatedByUser" class="form-label"></label>
                <input asp-for="CreatedByUser" class="form-control" placeholder="admin@meatpro.local" />
                <span asp-validation-for="CreatedByUser" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Priority plan for retail contract"></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>
        </div>
</div>
