@model MeatPro.ViewModels.ProductionPlanDetailsViewModel
@{
    ViewData["Title"] = Model.PlanCode;
}

<div class="module-card">
    <div class="section-title align-items-start flex-column flex-md-row">
        <div>
            <div class="section-kicker text-dark">Production</div>
            <h1 class="h3 mb-1">@Model.PlanCode</h1>
            <p class="text-secondary mb-0">@Model.ProductName | @Model.StartDate.ToString("yyyy-MM-dd") &ndash; @Model.EndDate.ToString("yyyy-MM-dd")</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-meatpro"><i class="bi bi-pencil me-1"></i>Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</a>
            <a asp-action="Index" class="btn btn-outline-meatpro"><i class="bi bi-arrow-left me-1"></i>Back to list</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
    }

    <div class="dashboard-grid mb-4">
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Status</div>
                <strong class="metric-value">@Model.Status</strong>
            </div>
            <div class="metric-caption mt-1">Current state</div>
        </div>
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Planned Quantity</div>
                <strong class="metric-value">@Model.PlannedQuantity.ToString("N0")</strong>
            </div>
            <div class="metric-caption mt-1">Production target</div>
        </div>
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Product</div>
                <strong class="metric-value">@Model.ProductName</strong>
            </div>
            <div class="metric-caption mt-1">Production item</div>
        </div>
        <div class="span-3 metric-card">
            <div class="d-flex justify-content-between align-items-center">
                <div class="metric-caption">Created By</div>
                <strong class="metric-value">@Model.CreatedByUser</strong>
            </div>
            <div class="metric-caption mt-1">Plan author</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="page-card p-4 h-100">
                    <h2 class="h6 text-uppercase text-secondary mb-3">Plan details</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-secondary">Plan Code</dt>
                        <dd class="col-sm-8">@Model.PlanCode</dd>

                        <dt class="col-sm-4 text-secondary">Product</dt>
                        <dd class="col-sm-8">@Model.ProductName</dd>

                        <dt class="col-sm-4 text-secondary">Planned Quantity</dt>
                        <dd class="col-sm-8">@Model.PlannedQuantity.ToString("N0")</dd>

                        <dt class="col-sm-4 text-secondary">Start Date</dt>
                        <dd class="col-sm-8">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

                        <dt class="col-sm-4 text-secondary">End Date</dt>
                        <dd class="col-sm-8">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

                        <dt class="col-sm-4 text-secondary">Notes</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Notes) ? "None" : Model.Notes)</dd>

                        <dt class="col-sm-4 text-secondary">Created</dt>
                        <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>

                        <dt class="col-sm-4 text-secondary">Updated</dt>
                        <dd class="col-sm-8">@(Model.UpdatedAtUtc is null ? "Never" : Model.UpdatedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") + " UTC")</dd>
                    </dl>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-card p-4 h-100">
                    <h2 class="h6 text-uppercase text-secondary mb-3">Status</h2>
                    <span class="fw-semibold text-@Model.StatusTone mb-3">@Model.Status</span>
                    <p class="text-secondary mb-3">This plan is currently <strong>@Model.Status</strong>.</p>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-meatpro w-100 mb-2"><i class="bi bi-pencil me-1"></i>Edit Plan</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger w-100"><i class="bi bi-trash me-1"></i>Delete Plan</a>
            </div>
        </div>
    </div>
</div>
