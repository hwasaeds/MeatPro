@model MeatPro.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign in";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MeatPro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        * { box-sizing: border-box; }

        .login-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fafaf9;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            padding: 1.5rem;
            position: relative;
            overflow: hidden;
            color: #0f172a;
        }

        .login-page ::selection { background: #8b0000; color: #fff; }

        .login-glow {
            position: fixed;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            filter: blur(160px);
            pointer-events: none;
            z-index: 0;
        }
        .login-glow.g1 { top: -250px; left: -150px; background: #8b0000; opacity: 0.08; }
        .login-glow.g2 { bottom: -250px; right: -150px; background: #d4af37; opacity: 0.06; }

        .login-wrapper {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 460px;
        }

        .login-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 2.5rem 2rem;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-header .brand-icon {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            background: #8b0000;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1.15rem;
            letter-spacing: 0.08em;
            box-shadow: 0 4px 12px rgba(139, 0, 0, 0.25);
            margin-bottom: 1.2rem;
            color: #fff;
        }

        .login-header h1 {
            font-size: 1.5rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 0.35rem;
            letter-spacing: -0.02em;
        }

        .login-header p {
            font-size: 0.9rem;
            color: #64748b;
            margin: 0;
        }

        .login-card .form-label {
            color: #475569;
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 0.4rem;
        }

        .login-card .form-control {
            background: #fafaf9;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 0.85rem 1.1rem;
            color: #0f172a;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }
        .login-card .form-control:focus {
            background: #fff;
            border-color: #8b0000;
            box-shadow: 0 0 0 3px rgba(139, 0, 0, 0.1);
            color: #0f172a;
        }
        .login-card .form-control::placeholder { color: #94a3b8; }
        .login-card .form-control.is-invalid { border-color: #e74c3c; }

        .login-card .form-check-label {
            color: #475569;
            font-size: 0.9rem;
        }
        .login-card .form-check-input {
            background-color: #f1f5f9;
            border-color: #e2e8f0;
        }
        .login-card .form-check-input:checked {
            background-color: #8b0000;
            border-color: #8b0000;
        }

        .login-card .btn-login {
            padding: 0.85rem;
            border-radius: 8px;
            font-weight: 700;
            font-size: 1rem;
            background: #8b0000;
            color: #fff;
            border: 0;
            box-shadow: 0 4px 14px rgba(139, 0, 0, 0.25);
            transition: all 0.2s ease;
            width: 100%;
        }
        .login-card .btn-login:hover { background: #a30000; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(139, 0, 0, 0.35); }
        .login-card .btn-login:active { transform: translateY(0); }

        .login-card .validation-summary-errors {
            background: #fef2f2;
            border: 1px solid rgba(139, 0, 0, 0.15);
            border-radius: 12px;
            padding: 0.75rem 1rem;
            font-size: 0.85rem;
            color: #991b1b;
            margin-bottom: 1rem;
        }
        .login-card .validation-summary-errors ul { margin: 0; padding-left: 1.2rem; }
        .login-card .field-validation-error { color: #991b1b; font-size: 0.8rem; }

        .login-back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            color: #94a3b8;
            font-size: 0.85rem;
            text-decoration: none;
            transition: color 0.2s ease;
            margin-bottom: 1.5rem;
        }
        .login-back-link:hover { color: #475569; }

        @@media (max-width: 480px) {
            .login-card { padding: 2rem 1.2rem; }
        }
    </style>
</head>
<body class="login-page">
    <div class="login-glow g1"></div>
    <div class="login-glow g2"></div>

    <div class="login-wrapper">
        <a asp-controller="Home" asp-action="Index" class="login-back-link">
            <i class="bi bi-arrow-left"></i> Back to home
        </a>

        <div class="login-card">
            <div class="login-header">
                <div class="brand-icon">MP</div>
                <h1>Welcome back!</h1>
                <p>Sign in to your MeatPro workspace</p>
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label">Email or username</label>
                    <input asp-for="UserName" class="form-control" placeholder="you@company.com" />
                    <span asp-validation-for="UserName" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">Keep me signed in</label>
                </div>

                <button type="submit" class="btn-login">Sign in <i class="bi bi-arrow-right ms-1"></i></button>
            </form>


        </div>
    </div>
</body>
</html>
