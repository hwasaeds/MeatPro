@{
    Layout = null;
    ViewData["Title"] = "Access denied";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MeatPro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .access-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(160deg, #0b0b0b 0%, #1a1a1a 50%, #0f0f0f 100%);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            padding: 1.5rem;
            position: relative;
            overflow: hidden;
        }

        .access-glow {
            position: fixed;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            filter: blur(140px);
            pointer-events: none;
            z-index: 0;
        }
        .access-glow.g1 { top: -200px; right: -100px; background: #8b0000; opacity: 0.15; }
        .access-glow.g2 { bottom: -200px; left: -100px; background: #d4af37; opacity: 0.08; }

        .access-card {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 420px;
            background: rgba(255, 255, 255, 0.04);
            backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 28px;
            padding: 3rem 2rem;
            text-align: center;
            box-shadow: 0 32px 80px rgba(0, 0, 0, 0.6);
        }

        .access-card .icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: rgba(139, 0, 0, 0.15);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: #e74c3c;
            margin-bottom: 1.5rem;
        }

        .access-card h1 {
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 0.5rem;
        }

        .access-card p {
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.95rem;
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .access-card .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.85rem 2rem;
            border-radius: 14px;
            font-weight: 700;
            font-size: 0.95rem;
            background: linear-gradient(145deg, #8b0000, #5f0000);
            color: #fff;
            border: 0;
            box-shadow: 0 12px 32px rgba(139, 0, 0, 0.35);
            text-decoration: none;
            transition: all 0.2s ease;
        }
        .access-card .btn-back:hover { transform: translateY(-1px); box-shadow: 0 16px 40px rgba(139, 0, 0, 0.45); color: #fff; }
    </style>
</head>
<body class="access-page">
    <div class="access-glow g1"></div>
    <div class="access-glow g2"></div>

    <div class="access-card">
        <div class="icon"><i class="bi bi-shield-exclamation"></i></div>
        <h1>Access denied</h1>
        <p>Your account does not have permission to access this area. Contact your administrator if you need elevated access.</p>
        <a asp-controller="Dashboard" asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left"></i> Back to dashboard
        </a>
    </div>
</body>
</html>
