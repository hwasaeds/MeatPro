@{
    ViewData["Title"] = "Access Denied";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="card text-center shadow-lg" style="max-width: 480px; width: 100%;">
        <div class="card-body py-5">
            <i class="bi bi-shield-exclamation text-danger" style="font-size: 4rem;"></i>
            <h1 class="card-title mt-3 fw-bold">Access Denied</h1>
            <p class="card-text text-muted fs-5">You do not have permission to view this page.</p>
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg mt-3">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>
